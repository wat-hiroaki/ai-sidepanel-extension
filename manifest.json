{
  "manifest_version": 3,
  "name": "AI Sidebar",
  "version": "2.0.1",
  "description": "Quick access to AI chat services from a side panel",
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "sidePanel",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://*.anthropic.com/*",
    "https://gemini.google.com/*",
    "https://accounts.google.com/*",
    "https://chatgpt.com/*",
    "https://*.openai.com/*",
    "https://login.chatgpt.com/*",
    "https://grok.com/*",
    "https://*.grok.com/*",
    "https://*.x.ai/*",
    "https://x.com/*"
  ],
  "action": {
    "default_title": "Toggle AI Sidebar"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://*.anthropic.com/*",
        "https://gemini.google.com/*",
        "https://accounts.google.com/*",
        "https://chatgpt.com/*",
        "https://*.openai.com/*",
        "https://login.chatgpt.com/*",
        "https://grok.com/*",
        "https://*.grok.com/*",
        "https://*.x.ai/*",
        "https://x.com/*"
      ],
      "js": ["frame-bypass.js"],
      "all_frames": true,
      "match_origin_as_fallback": true,
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+A"
      },
      "description": "Toggle AI Side Panel"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
